<div class="page-head">
  <div>
    <h2>Pengajuan Saya</h2>
    <p>Riwayat pengajuan dosen pembimbing karya akhir Anda.</p>
  </div>
  <a class="btn btn-gold" href="/mahasiswa/pengajuan/baru">➕ Ajukan Dosen Baru</a>
</div>

<div class="card">
  <form method="GET" action="/mahasiswa/dashboard" class="search-bar">
    <div class="field">
      <label for="q">Cari</label>
      <input type="text" id="q" name="q" placeholder="Cari berdasarkan nama, NIM, atau prodi" value="<%= q %>">
    </div>
    <div class="field">
      <label for="status">Status</label>
      <select id="status" name="status">
        <option value="">Semua Status</option>
        <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Menunggu</option>
        <option value="diproses" <%= statusFilter === 'diproses' ? 'selected' : '' %>>Diproses</option>
        <option value="disetujui" <%= statusFilter === 'disetujui' ? 'selected' : '' %>>Disetujui</option>
        <option value="ditolak" <%= statusFilter === 'ditolak' ? 'selected' : '' %>>Ditolak</option>
      </select>
    </div>
    <div class="field-actions">
      <button class="btn btn-primary" type="submit">🔍 Cari</button>
      <% if (q || statusFilter) { %><a class="btn btn-outline" href="/mahasiswa/dashboard">Reset</a><% } %>
    </div>
  </form>
</div>

<% if (pengajuanList.length === 0) { %>
  <div class="card empty-state">
    <h3><%= (q || statusFilter) ? 'Tidak ada pengajuan yang cocok' : 'Belum ada pengajuan' %></h3>
    <p><%= (q || statusFilter) ? 'Coba ubah kata kunci atau filter pencarian.' : 'Anda belum pernah mengajukan dosen pembimbing karya akhir.' %></p>
    <% if (!(q || statusFilter)) { %>
      <a class="btn btn-primary" href="/mahasiswa/pengajuan/baru" style="margin-top:12px;">Buat Pengajuan Pertama</a>
    <% } %>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nama</th>
            <th>Prodi</th>
            <th>Dosen Ditetapkan</th>
            <th>Status</th>
            <th>Diajukan</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% pengajuanList.forEach(p => { %>
            <tr>
              <td><%= p.namaLengkap %> <br><span style="color:var(--ink-soft);font-size:12px;"><%= p.nim %></span></td>
              <td><%= p.prodi %></td>
              <td><%= p.dosenDitetapkan ? p.dosenDitetapkan.nama : '-' %></td>
              <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
              <td><%= p.createdAt.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
              <td><a class="btn btn-outline btn-sm" href="/mahasiswa/pengajuan/<%= p._id %>">Lihat</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
